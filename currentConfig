    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter the initials of the scouter.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Driver Station",
          "description": "If you are scouting the same driver station each match, choose here",
          "type": "select",
          "required": false,
          "code": "driverStation",
          "formResetBehavior": "preserve",
          "defaultValue": "",
          "choices": {
            "R1": "Red 1",
            "R2": "Red 2",
            "R3": "Red 3",
            "B1": "Blue 1",
            "B2": "Blue 2",
            "B3": "Blue 3"
          }
        },
        {
          "title": "Match Number",
          "description": "Select the match number.",
          "type": "TBA-match-number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        },
        {
          "title": "Team #:",
          "description": "Select team and robot position",
          "type": "TBA-team-and-robot",
          "required": true,
          "code": "teamAndRobot",
          "formResetBehavior": "reset",
          "defaultValue": null
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "startPos",
          "formResetBehavior": "reset",
          "choices": {
            "OT": "A. Outpost Trench",
            "OBFT": "B. Outpost Bump Favoring Trench",
            "OBFH": "C. Outpost Bump Favoring Hub",
            "H": "D. Hub",
            "DBFH": "E. Depot Bump Favoring Hub",
            "DBFT": "F. Depot Bump Favoring Trench",
            "DT": "G. Depot Trench"
          }
        },
        {
          "title": "Field Layout: Red",
          "description": "Reference diagram of the field",
          "type": "image",
          "required": false,
          "code": "fieldLayoutR",
          "formResetBehavior": "preserve",
          "defaultValue": "https://i.ibb.co/7Jh1hZXL/Scouting-Field-Map-Layout.png",
          "width": 300,
          "height": 150,
          "alt": "2026 FRC Field Layout Diagram"
        },
        {
          "title": "Field Layout: Blue",
          "description": "Reference diagram of the field",
          "type": "image",
          "required": false,
          "code": "fieldLayoutB",
          "formResetBehavior": "preserve",
          "defaultValue": "https://i.ibb.co/Ldg8Jcbt/Scouting-Field-Map-Layout-2.png",
          "width": 300,
          "height": 150,
          "alt": "2026 FRC Field Layout Diagram"
        }
      ]
    },
    {
      "name": "Autonomous",
      "fields": [
        {
          "title": "Actions",
          "description": "Track actions performed during autonomous.",
          "type": "action-tracker",
          "required": false,
          "code": "autoActions",
          "formResetBehavior": "reset",
          "defaultValue": null,
          "mode": "hold",
          "actions": [
            {
              "label": "Scoring",
              "code": "scoring"
            },
            {
              "label": "Ground Collect",
              "code": "ground_collect"
            },
            {
              "label": "Passing",
              "code": "passing"
            },
            {
              "label": "Stuck on Fuel",
              "code": "Stuck on Fuel"
            },
            {
              "label": "Climbing",
              "code": "climbing"
            }
          ],
          "timerDuration": 15,
          "autoStopSeconds": 25
        },
        {
          "title": "Collected From",
          "description": "Where on the field did the robot collect fuel from?",
          "type": "multi-select",
          "required": true,
          "code": "collectLocation",
          "formResetBehavior": "reset",
          "choices": {
            "No Collection": "Didn't Collect Fuel",
            "Midfield": "Collected from Midfield/Neutral Zone",
            "Depot": "Collected from Depot",
            "Outpost": "Collected from Outpost"
          }
        },
        {
          "title": "Climbed",
          "description": "Did the robot climb during autonomous?",
          "type": "select",
          "required": false,
          "code": "autoClimbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "Didn't Climb",
            "Yes": "Climbed",
            "F": "Failed Climb"
          }
        },
        {
          "title": "Climbed Where?",
          "description": "Where on the tower did the robot climb in autonomous?",
          "type": "select",
          "required": false,
          "code": "autoClimbPos",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "Didn't Climb",
            "Out": "(1) Outpost Side",
            "Mid": "(2) Middle",
            "Dep": "(3) Depot Side"
          }
        }
      ]
    },
